<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Big Island Weather — Hawai'i</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@300;400;500&family=Spectral:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --ocean: #0a2a3a;
    --deep: #061820;
    --lava: #c0392b;
    --lava-glow: #e74c3c;
    --gold: #d4a843;
    --mist: #7fb3c8;
    --foam: #e8f4f8;
    --leaf: #2d6a4f;
    --sand: #f0d9a0;
    --sky-clear: #87ceeb;
    --sky-cloud: #b0bec5;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--deep);
    color: var(--foam);
    font-family: 'Spectral', serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ANIMATED OCEAN BACKGROUND */
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(10,42,58,0.95) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(45,106,79,0.3) 0%, transparent 60%),
      radial-gradient(ellipse 100% 80% at 50% 100%, rgba(6,24,32,1) 0%, transparent 80%),
      linear-gradient(160deg, #061820 0%, #0a2a3a 40%, #0d3347 70%, #061820 100%);
    pointer-events: none;
  }

  .wave {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 200%;
    height: 120px;
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }

  .wave svg { width: 100%; height: 100%; }
  .wave1 { animation: waveMove 12s linear infinite; }
  .wave2 { animation: waveMove 18s linear infinite reverse; opacity: 0.05; bottom: 10px; }

  @keyframes waveMove {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* STARS */
  .stars {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .star {
    position: absolute;
    background: white;
    border-radius: 50%;
    animation: twinkle var(--dur, 3s) ease-in-out infinite var(--delay, 0s);
    opacity: 0;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0; }
    50% { opacity: var(--max-op, 0.6); }
  }

  /* HEADER */
  header {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 60px 20px 40px;
  }

  .island-name {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: clamp(14px, 3vw, 18px);
    color: var(--gold);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 1s ease forwards 0.3s;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(42px, 8vw, 88px);
    font-weight: 700;
    line-height: 0.9;
    color: var(--foam);
    opacity: 0;
    animation: fadeUp 1s ease forwards 0.5s;
  }

  h1 span {
    display: block;
    color: var(--mist);
    font-weight: 400;
    font-style: italic;
    font-size: 0.55em;
  }

  .date-line {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--mist);
    margin-top: 18px;
    opacity: 0;
    animation: fadeUp 1s ease forwards 0.7s;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* DIVIDER */
  .divider {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto 50px;
    padding: 0 40px;
    opacity: 0;
    animation: fadeUp 1s ease forwards 0.9s;
  }

  .divider-line { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
  .divider-icon { color: var(--gold); font-size: 18px; }

  /* LOCATION TABS */
  .location-tabs {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 0 20px 40px;
    opacity: 0;
    animation: fadeUp 1s ease forwards 1.1s;
  }

  .tab {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--mist);
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 10px 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 2px;
    backdrop-filter: blur(10px);
  }

  .tab:hover {
    background: rgba(212,168,67,0.15);
    border-color: var(--gold);
    color: var(--gold);
  }

  .tab.active {
    background: rgba(212,168,67,0.2);
    border-color: var(--gold);
    color: var(--gold);
  }

  /* MAIN CONTENT */
  .content {
    position: relative;
    z-index: 10;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px 80px;
  }

  /* LOCATION PANEL */
  .location-panel {
    display: none;
    animation: panelIn 0.5s ease forwards;
  }

  .location-panel.active { display: block; }

  @keyframes panelIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* CURRENT CONDITIONS */
  .current-card {
    background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 50px;
    margin-bottom: 30px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    backdrop-filter: blur(20px);
    position: relative;
    overflow: hidden;
  }

  .current-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .current-temp-area { text-align: center; }

  .weather-icon-big {
    font-size: 80px;
    display: block;
    margin-bottom: 16px;
    filter: drop-shadow(0 0 20px rgba(212,168,67,0.4));
    animation: floatIcon 4s ease-in-out infinite;
  }

  @keyframes floatIcon {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .temp-big {
    font-family: 'Playfair Display', serif;
    font-size: clamp(60px, 10vw, 96px);
    font-weight: 700;
    line-height: 1;
    color: var(--foam);
  }

  .temp-big sup {
    font-size: 0.35em;
    vertical-align: super;
    color: var(--mist);
  }

  .condition-text {
    font-family: 'Spectral', serif;
    font-style: italic;
    font-size: 20px;
    color: var(--mist);
    margin-top: 8px;
  }

  /* STATS GRID */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .stat-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 3px;
    padding: 20px;
    transition: all 0.3s ease;
  }

  .stat-card:hover {
    background: rgba(212,168,67,0.08);
    border-color: rgba(212,168,67,0.3);
    transform: translateY(-2px);
  }

  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--mist);
    opacity: 0.7;
    margin-bottom: 6px;
  }

  .stat-val {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--foam);
  }

  .stat-val small {
    font-size: 14px;
    font-family: 'DM Mono', monospace;
    color: var(--mist);
  }

  /* LOCATION DESCRIPTION */
  .location-desc {
    font-family: 'Spectral', serif;
    font-style: italic;
    font-size: 16px;
    color: var(--mist);
    margin-top: 20px;
    line-height: 1.7;
    opacity: 0.8;
    text-align: center;
  }

  /* SECTION TITLE */
  .section-title {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(212,168,67,0.4), transparent);
  }

  /* 5-DAY FORECAST */
  .forecast-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    margin-bottom: 30px;
  }

  .forecast-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 3px;
    padding: 24px 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .forecast-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 0;
    background: linear-gradient(180deg, transparent, rgba(212,168,67,0.1));
    transition: height 0.3s ease;
  }

  .forecast-card:hover {
    border-color: rgba(212,168,67,0.4);
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .forecast-card:hover::after { height: 100%; }

  .forecast-card.today {
    border-color: rgba(212,168,67,0.5);
    background: rgba(212,168,67,0.08);
  }

  .forecast-day {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mist);
    margin-bottom: 12px;
  }

  .forecast-card.today .forecast-day { color: var(--gold); }

  .forecast-icon {
    font-size: 36px;
    margin-bottom: 10px;
    display: block;
    filter: drop-shadow(0 0 8px rgba(212,168,67,0.3));
  }

  .forecast-high {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--foam);
  }

  .forecast-high sup {
    font-size: 12px;
    color: var(--mist);
    font-family: 'DM Mono', monospace;
  }

  .rain-bar-wrap {
    margin-top: 10px;
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
  }

  .rain-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--mist), #4fc3f7);
    border-radius: 2px;
    transition: width 1s ease;
  }

  .rain-pct {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--mist);
    opacity: 0.7;
    margin-top: 6px;
  }

  /* RAIN CHANCE CHART */
  .chart-area {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 3px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    height: 120px;
    margin-top: 20px;
  }

  .bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    height: 100%;
    justify-content: flex-end;
  }

  .bar-fill {
    width: 100%;
    max-width: 48px;
    border-radius: 2px 2px 0 0;
    background: linear-gradient(180deg, #4fc3f7, rgba(127,179,200,0.4));
    transition: height 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
  }

  .bar-fill::before {
    content: attr(data-val);
    position: absolute;
    top: -22px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--mist);
    white-space: nowrap;
  }

  .bar-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: var(--mist);
    opacity: 0.6;
    text-align: center;
  }

  /* MAP OVERVIEW */
  .island-overview {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 3px;
    padding: 30px;
    text-align: center;
    position: relative;
  }

  .island-svg-wrap {
    max-width: 400px;
    margin: 0 auto;
    position: relative;
    cursor: pointer;
  }

  .island-svg-wrap svg {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 0 30px rgba(10,42,58,0.8));
  }

  .map-dot {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--gold);
    border: 2px solid var(--foam);
    transform: translate(-50%, -50%);
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 0 12px rgba(212,168,67,0.6);
    animation: pulse 2s ease-in-out infinite;
  }

  .map-dot:hover, .map-dot.active-dot {
    transform: translate(-50%, -50%) scale(1.6);
    box-shadow: 0 0 20px rgba(212,168,67,0.9);
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 12px rgba(212,168,67,0.6); }
    50% { box-shadow: 0 0 20px rgba(212,168,67,1), 0 0 40px rgba(212,168,67,0.3); }
  }

  .map-tooltip {
    position: absolute;
    background: rgba(6,24,32,0.95);
    border: 1px solid rgba(212,168,67,0.4);
    border-radius: 3px;
    padding: 8px 14px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--foam);
    pointer-events: none;
    white-space: nowrap;
    transform: translate(-50%, -130%);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 20;
  }

  .map-dot:hover .map-tooltip { opacity: 1; }

  /* ALERT BANNER */
  .alert-banner {
    background: rgba(192,57,43,0.15);
    border: 1px solid rgba(192,57,43,0.4);
    border-radius: 3px;
    padding: 14px 20px;
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #e88;
  }

  .alert-icon { font-size: 16px; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .current-card {
      grid-template-columns: 1fr;
      padding: 30px 20px;
    }

    .forecast-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .forecast-grid .forecast-card:nth-child(4),
    .forecast-grid .forecast-card:nth-child(5) {
      grid-column: span 1;
    }

    .stats-grid { grid-template-columns: 1fr 1fr; }
    .bar-chart { gap: 8px; }
  }

  @media (max-width: 480px) {
    .forecast-grid { grid-template-columns: repeat(2, 1fr); }
    .forecast-grid .forecast-card:last-child { grid-column: span 2; }
    header { padding: 40px 20px 20px; }
    .current-card { padding: 24px 16px; }
  }

  /* FOOTER */
  footer {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 20px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--mist);
    opacity: 0.4;
    letter-spacing: 0.15em;
  }

  /* ── AI CHATBOT ── */
  .chat-fab {
    position: fixed;
    bottom: 32px;
    right: 32px;
    z-index: 1000;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), #b8860b);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    box-shadow: 0 4px 24px rgba(212,168,67,0.5), 0 0 0 0 rgba(212,168,67,0.4);
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease;
    animation: fabPulse 3s ease-in-out infinite;
  }

  .chat-fab:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 32px rgba(212,168,67,0.7);
  }

  @keyframes fabPulse {
    0%, 100% { box-shadow: 0 4px 24px rgba(212,168,67,0.5), 0 0 0 0 rgba(212,168,67,0.3); }
    50% { box-shadow: 0 4px 24px rgba(212,168,67,0.5), 0 0 0 10px rgba(212,168,67,0); }
  }

  .chat-fab .fab-tooltip {
    position: absolute;
    right: 70px;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(6,24,32,0.95);
    border: 1px solid rgba(212,168,67,0.4);
    border-radius: 3px;
    padding: 7px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--gold);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .chat-fab:hover .fab-tooltip { opacity: 1; }

  .chat-window {
    position: fixed;
    bottom: 104px;
    right: 32px;
    z-index: 999;
    width: 380px;
    max-width: calc(100vw - 40px);
    height: 520px;
    max-height: calc(100vh - 140px);
    background: rgba(6,18,28,0.97);
    border: 1px solid rgba(212,168,67,0.3);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(212,168,67,0.1);
    backdrop-filter: blur(20px);
    transform: scale(0.85) translateY(20px);
    transform-origin: bottom right;
    opacity: 0;
    pointer-events: none;
    transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1);
  }

  .chat-window.open {
    transform: scale(1) translateY(0);
    opacity: 1;
    pointer-events: all;
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(212,168,67,0.08);
    flex-shrink: 0;
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--gold), #2d6a4f);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }

  .chat-header-info { flex: 1; }

  .chat-header-name {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    color: var(--foam);
  }

  .chat-header-status {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: #4caf50;
    display: flex;
    align-items: center;
    gap: 5px;
    margin-top: 2px;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4caf50;
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .chat-close {
    background: none;
    border: none;
    color: var(--mist);
    font-size: 18px;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s, transform 0.2s;
    padding: 4px;
  }

  .chat-close:hover { opacity: 1; transform: rotate(90deg); }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    scroll-behavior: smooth;
  }

  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: rgba(212,168,67,0.3); border-radius: 2px; }

  .msg {
    display: flex;
    gap: 10px;
    animation: msgIn 0.3s ease forwards;
    opacity: 0;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .msg.user { flex-direction: row-reverse; }

  .msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .msg.bot .msg-avatar { background: linear-gradient(135deg, var(--gold), #2d6a4f); }
  .msg.user .msg-avatar { background: rgba(127,179,200,0.2); border: 1px solid rgba(127,179,200,0.3); }

  .msg-bubble {
    max-width: 82%;
    padding: 11px 15px;
    border-radius: 4px;
    font-family: 'Spectral', serif;
    font-size: 14px;
    line-height: 1.6;
  }

  .msg.bot .msg-bubble {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--foam);
    border-radius: 2px 12px 12px 12px;
  }

  .msg.user .msg-bubble {
    background: rgba(212,168,67,0.15);
    border: 1px solid rgba(212,168,67,0.25);
    color: var(--foam);
    border-radius: 12px 2px 12px 12px;
    text-align: right;
  }

  .msg-bubble strong { color: var(--gold); font-style: normal; }
  .msg-bubble em { color: var(--mist); font-size: 12px; display: block; margin-top: 4px; }

  /* Typing indicator */
  .typing-indicator {
    display: flex;
    gap: 10px;
    animation: msgIn 0.3s ease forwards;
    opacity: 0;
  }

  .typing-dots {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 2px 12px 12px 12px;
    padding: 14px 18px;
    display: flex;
    gap: 5px;
    align-items: center;
  }

  .typing-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--mist);
    animation: typingBounce 1.2s ease-in-out infinite;
  }

  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  /* Suggestions */
  .chat-suggestions {
    padding: 10px 20px 0;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .suggestion-chip {
    background: rgba(212,168,67,0.08);
    border: 1px solid rgba(212,168,67,0.25);
    border-radius: 20px;
    padding: 5px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--gold);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .suggestion-chip:hover {
    background: rgba(212,168,67,0.18);
    border-color: var(--gold);
    transform: translateY(-1px);
  }

  .chat-input-area {
    display: flex;
    gap: 10px;
    padding: 14px 16px;
    border-top: 1px solid rgba(255,255,255,0.07);
    flex-shrink: 0;
  }

  .chat-input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px;
    padding: 10px 14px;
    color: var(--foam);
    font-family: 'Spectral', serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
    resize: none;
  }

  .chat-input::placeholder { color: rgba(127,179,200,0.4); font-style: italic; }
  .chat-input:focus { border-color: rgba(212,168,67,0.5); }

