<!-- ── AI CHATBOT ── -->
<button class="chat-fab" id="chatFab" onclick="toggleChat()" aria-label="Open weather assistant">
  🌺
  <span class="fab-tooltip">Ask the Weather Guide</span>
</button>

<div class="chat-window" id="chatWindow">
  <div class="chat-header">
    <div class="chat-avatar">🌺</div>
    <div class="chat-header-info">
      <div class="chat-header-name">Kai — Weather Guide</div>
      <div class="chat-header-status"><span class="status-dot"></span>ONLINE · BIG ISLAND</div>
    </div>
    <button class="chat-close" onclick="toggleChat()">✕</button>
  </div>

  <div class="chat-messages" id="chatMessages"></div>

  <div class="chat-suggestions" id="chatSuggestions">
    <button class="suggestion-chip" onclick="sendSuggestion(this)">Best beach weather?</button>
    <button class="suggestion-chip" onclick="sendSuggestion(this)">Will it rain in Hilo?</button>
    <button class="suggestion-chip" onclick="sendSuggestion(this)">Volcano visit this week?</button>
    <button class="suggestion-chip" onclick="sendSuggestion(this)">What's vog?</button>
  </div>

  <div class="chat-input-area">
    <input
      class="chat-input"
      id="chatInput"
      type="text"
      placeholder="Ask about Big Island weather…"
      maxlength="300"
      onkeydown="if(event.key==='Enter')sendMessage()"
    />
    <button class="chat-send" id="chatSend" onclick="sendMessage()">➤</button>
  </div>
</div>

<script>
  // Date line
  const d = new Date();
  const opts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
  document.getElementById('dateLine').textContent = '— ' + d.toLocaleDateString('en-US', opts) + ' —';

  // Stars
  const starsEl = document.getElementById('stars');
  for (let i = 0; i < 80; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 2 + 0.5;
    s.style.cssText = `
      width:${size}px; height:${size}px;
      top:${Math.random()*60}%;
      left:${Math.random()*100}%;
      --dur:${2+Math.random()*4}s;
      --delay:${Math.random()*5}s;
      --max-op:${0.3+Math.random()*0.5};
    `;
    starsEl.appendChild(s);
  }

  // Tab switching
  function showLocation(loc) {
    // panels
    document.querySelectorAll('.location-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + loc).classList.add('active');
    // tabs
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    const labels = { hilo:'Hilo', kona:'Kona', waimea:'Waimea', pahala:'Volcano / Pahala' };
    document.querySelectorAll('.tab').forEach(t => {
      if (t.textContent.trim() === labels[loc]) t.classList.add('active');
    });
    // map dots
    document.querySelectorAll('.map-dot').forEach(d => d.classList.remove('active-dot'));
    const dotEl = document.getElementById('dot-' + loc);
    if (dotEl) dotEl.classList.add('active-dot');

    // Animate bars on panel switch
    setTimeout(() => {
      const panel = document.getElementById('panel-' + loc);
      panel.querySelectorAll('.bar-fill').forEach(bar => {
        const h = bar.style.height;
        bar.style.height = '0%';
        setTimeout(() => bar.style.height = h, 50);
      });
    }, 100);
  }

  // Initial bar animation
  setTimeout(() => {
    document.querySelectorAll('#panel-hilo .bar-fill').forEach(bar => {
      const h = bar.style.height;
      bar.style.height = '0%';
      setTimeout(() => bar.style.height = h, 50);
    });
  }, 800);

  // Forecast card hover ripple
  document.querySelectorAll('.forecast-card').forEach(card => {
    card.addEventListener('mouseenter', function() {
      this.style.transition = 'all 0.3s cubic-bezier(0.34,1.56,0.64,1)';
    });
  });

  // ── AI CHATBOT ──
  const WEATHER_CONTEXT = `
You are Kai, a friendly and knowledgeable Big Island Hawai'i weather guide embedded in a weather forecast website.
You have access to the following LIVE forecast data as of April 3, 2026:

HILO (windward, east side, 36 ft elevation):
- Current: 67°F, Cloudy
- Fri: High 67°F, 25% rain | Sat: 70°F, 10% | Sun: 70°F, 25% | Mon: 69°F, 20% | Tue: 69°F, 40%

KONA (leeward, west side, 30 ft elevation):
- Current: 72°F, Cloudy
- Fri: High 72°F, 10% rain | Sat: 72°F, 0% | Sun: 72°F, 10% | Mon: 73°F, 10% | Tue: 75°F, 20%

WAIMEA (upcountry, 2,670 ft elevation):
- Current: 65°F, Cloudy
- Fri: 66°F, 35% | Sat: 68°F, 20% | Sun: 68°F, 10% | Mon: 69°F, 35% | Tue: 70°F, 20%

VOLCANO / PAHALA (Ka'ū district, 3,000+ ft elevation):
- Current: 52°F, Cloudy/Misty
- Fri: 52°F, 20% | Sat: 55°F, 35% | Sun: 54°F, 35% | Mon: 53°F, 20% | Tue: 49°F, 60% rain

IMPORTANT NOTES:
- Trade winds are active — typical windward (Hilo side) showers expected
- Kīlauea volcano may produce vog (volcanic smog) — visitors should check HVO (Hawaiian Volcano Observatory)
- The island has microclimates — it can be sunny in Kona while raining in Hilo simultaneously
- Hilo is one of the wettest cities in the US; Kona is typically sunny and dry

Answer conversationally, warmly, and with local flavor. Use Hawaiian words naturally (like "makai" for toward the ocean, "mauka" for toward the mountain). Keep responses concise — 2-4 sentences usually. If asked about activities, give practical weather-based advice. Use emojis sparingly but naturally.
  `.trim();

  let chatOpen = false;
  let conversationHistory = [];
  let greeted = false;

  function toggleChat() {
    chatOpen = !chatOpen;
    const win = document.getElementById('chatWindow');
    const fab = document.getElementById('chatFab');
    win.classList.toggle('open', chatOpen);
    fab.textContent = chatOpen ? '✕' : '🌺';
    fab.style.background = chatOpen
      ? 'linear-gradient(135deg, #555, #333)'
      : 'linear-gradient(135deg, #d4a843, #b8860b)';

    if (chatOpen && !greeted) {
      greeted = true;
      setTimeout(() => addBotMessage("Aloha! 🌺 I'm Kai, your Big Island weather guide. I have today's live forecast for Hilo, Kona, Waimea, and the Volcano area. What would you like to know?"), 400);
    }
    if (chatOpen) setTimeout(() => document.getElementById('chatInput').focus(), 400);
  }

  function addBotMessage(text) {
    const msgs = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'msg bot';
    div.innerHTML = `
      <div class="msg-avatar">🌺</div>
      <div class="msg-bubble">${text}</div>
    `;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function addUserMessage(text) {
    const msgs = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'msg user';
    div.innerHTML = `
      <div class="msg-avatar">👤</div>
      <div class="msg-bubble">${text}</div>
    `;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function showTyping() {
    const msgs = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'typing-indicator';
    div.id = 'typingIndicator';
    div.innerHTML = `
      <div class="msg-avatar" style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--gold),#2d6a4f);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">🌺</div>
      <div class="typing-dots"><span></span><span></span><span></span></div>
    `;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return div;
  }

  function removeTyping() {
    const el = document.getElementById('typingIndicator');
    if (el) el.remove();
  }

  function hideSuggestions() {
    const s = document.getElementById('chatSuggestions');
    if (s) s.style.display = 'none';
  }

  function sendSuggestion(btn) {
    const text = btn.textContent;
    hideSuggestions();
    processMessage(text);
  }

  function sendMessage() {
    const input = document.getElementById('chatInput');
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    hideSuggestions();
    processMessage(text);
  }

  async function processMessage(text) {
    addUserMessage(text);
    const sendBtn = document.getElementById('chatSend');
    const input = document.getElementById('chatInput');
    sendBtn.disabled = true;
    input.disabled = true;

    const typingEl = showTyping();

    conversationHistory.push({ role: 'user', content: text });

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: WEATHER_CONTEXT,
          messages: conversationHistory
        })
      });

      const data = await response.json();
      const reply = data.content?.map(b => b.text || '').join('') || "Sorry, I had trouble connecting. Please try again!";

      conversationHistory.push({ role: 'assistant', content: reply });

      removeTyping();
      addBotMessage(reply.replace(/\n/g, '<br>'));
    } catch (err) {
      removeTyping();
      addBotMessage("Hmm, the trade winds must be interfering with my signal 😅 Please try again in a moment.");
    }

    sendBtn.disabled = false;
    input.disabled = false;
    input.focus();
  }
</script>
</body>
</html>
